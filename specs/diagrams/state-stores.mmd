graph TB
    subgraph kubelet["Kubelet &lpar;source of truth&rpar;"]
        K["Active Claims<br/>Calls Prepare / Unprepare"]
    end

    subgraph driver["Driver Process &lpar;ephemeral&rpar;"]
        P["d.prepared map"]
        RC["Reconciler loop"]
    end

    subgraph hostpath["hostPath Volumes &lpar;survive pod restart&rpar;"]
        CP["checkpoint.json"]
        CDI["CDI specs<br/>/var/run/cdi/"]
    end

    subgraph emptydir["emptyDir Volumes &lpar;survive container restart&rpar;"]
        CF[".alloy config files<br/>/etc/alloy/config/"]
        SK["UDS sockets<br/>/var/run/alloy/"]
    end

    subgraph alloy["Alloy Process &lpar;ephemeral&rpar;"]
        AR["Runtime config"]
    end

    K -- "Prepare / Unprepare<br/>&lpar;sync, fast&rpar;" --> P
    P -- "save &lpar;sync&rpar;" --> CP
    CP -- "load on startup" --> P
    P -- "desired state" --> RC
    RC -. "write / delete<br/>&lpar;async, idempotent&rpar;" .-> CF
    RC -. "write / delete<br/>&lpar;async, idempotent&rpar;" .-> CDI
    RC -. "POST /-/reload<br/>&lpar;async&rpar;" .-> AR
    CF -- "alloy run reads" --> AR
    AR -- "creates on listen" --> SK

    style kubelet fill:#e8f4fd,stroke:#2196F3
    style driver fill:#fff3e0,stroke:#FF9800
    style hostpath fill:#e8f5e9,stroke:#4CAF50
    style emptydir fill:#fce4ec,stroke:#E91E63
    style alloy fill:#f3e5f5,stroke:#9C27B0
